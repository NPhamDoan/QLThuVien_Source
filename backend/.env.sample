# Server
PORT=3000

# Log level - điều khiển mức độ log hiển thị trong terminal
# Giá trị: debug | info | error | off
#   debug  = Log mọi request + body POST/PUT (chi tiết nhất)
#   info   = Log mọi request: method, url, status, thời gian (mặc định)
#   error  = Chỉ log request lỗi 4xx/5xx
#   off    = Tắt log hoàn toàn
LOG_LEVEL=info
